{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Babbily Help Center",
  "description": "Customer guides for chatting with AI models, using memory, connecting apps, managing teams, and understanding Babbily usage.",
  "colors": {
    "primary": "#D9363E",
    "light": "#F8585C",
    "dark": "#D9363E"
  },
  "favicon": {
    "light": "/images/Untitleddesign.png",
    "dark": "/images/Untitleddesign.png"
  },
  "logo": {
    "light": "/images/Untitleddesign.png",
    "dark": "/images/Untitleddesign.png",
    "href": "https://babbily.com"
  },
  "navigation": {
    "pages": [
      "index",
      {
        "group": "Get started",
        "icon": "rocket",
        "pages": [
          "quickstart",
          "features/account-and-settings",
          "features/chat-and-models"
        ]
      },
      {
        "group": "Chat and creation",
        "icon": "messages-square",
        "pages": [
          "features/file-attachments",
          "features/deep-research-and-search",
          "features/news",
          "features/translate",
          "features/voice-dictation",
          "features/image-and-video-generation",
          "features/context-window",
          "features/temporary-chat"
        ]
      },
      {
        "group": "Personalization",
        "icon": "sparkles",
        "pages": [
          "features/memory",
          "features/tools-and-skills",
          "features/saved-prompts",
          "features/connectors",
          "features/connector-capabilities"
        ]
      },
      {
        "group": "Workspace",
        "icon": "layout-dashboard",
        "pages": [
          "features/library-and-sharing",
          "features/teams"
        ]
      },
      {
        "group": "Billing and privacy",
        "icon": "shield-check",
        "pages": [
          "features/usage-budget",
          "features/billing-and-plans",
          "features/privacy-and-data"
        ]
      },
      {
        "group": "Troubleshooting",
        "icon": "wrench",
        "pages": [
          "troubleshooting/common-issues"
        ]
      },
      {
        "group": "Changelog",
        "icon": "rss",
        "pages": [
          "changelog/overview"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Babbily",
          "href": "https://babbily.com",
          "icon": "house"
        },
        {
          "anchor": "Support",
          "href": "https://support.babbily.com",
          "icon": "life-buoy"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://support.babbily.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Babbily",
      "href": "https://platform.babbily.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Inter"
  }
}
